<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import uet.fit.client.ui.view.CommitChoosingTableView?>
<fx:root spacing="16" style="-fx-background-color: #fff;" type="VBox" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uet.fit.client.ui.controller.env.ChooseVersionController">
	<children>
		<CommitChoosingTableView fx:id="tvCommits" />
		<HBox alignment="CENTER_RIGHT" spacing="8">
			<Button fx:id="btnBack" mnemonicParsing="false" onAction="#btnBack_Clicked" text="Back" AnchorPane.bottomAnchor="24.5" AnchorPane.rightAnchor="15.5">
			</Button>
			<Region minWidth="16" HBox.hgrow="ALWAYS" />
			<Button fx:id="btnNext" mnemonicParsing="false" onAction="#btnNext_Clicked" text="Next" AnchorPane.bottomAnchor="24.5" AnchorPane.rightAnchor="15.5">
			</Button>
		</HBox>
	</children>
	<padding>
		<Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
	</padding>
</fx:root>
