<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?><?import javafx.scene.control.Button?><?import javafx.scene.control.ComboBox?><?import javafx.scene.control.TableColumn?><?import javafx.scene.control.TableView?><?import javafx.scene.control.TextField?><?import javafx.scene.layout.AnchorPane?><?import javafx.scene.layout.HBox?><?import javafx.scene.layout.VBox?>
<fx:root fx:id="content" type="VBox" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
		fx:controller="uet.fit.client.ui.controller.cia.CommitsChoosingTableController">
	<HBox alignment="CENTER" spacing="4.0">
		<padding>
			<Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
		</padding>
		<Button fx:id="bClear" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" text="Clear"
				HBox.hgrow="ALWAYS"/>
		<AnchorPane HBox.hgrow="SOMETIMES">
			<TextField fx:id="tfAllFilterContent" disable="true" AnchorPane.bottomAnchor="0.0"
					AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
			<TextField fx:id="tfMessageFilterContent" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
					AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
			<TextField fx:id="tfCommitIDFilterContent" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
					AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
			<ComboBox fx:id="cbTagFilterContent" editable="true" AnchorPane.bottomAnchor="0.0"
					AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
			<ComboBox fx:id="cbBranchFilterContent" editable="true" AnchorPane.bottomAnchor="0.0"
					AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
		</AnchorPane>
		<ComboBox fx:id="cbFilterType" minHeight="-Infinity" minWidth="-Infinity" HBox.hgrow="ALWAYS"/>
		<Button fx:id="bFilter" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" text="Filter"
				HBox.hgrow="ALWAYS"/>
	</HBox>
	<TableView fx:id="tvAllCommits" VBox.vgrow="ALWAYS">
		<padding>
			<Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
		</padding>
		<columns>
			<TableColumn fx:id="clChoose" editable="false" maxWidth="30.0" minWidth="30.0" sortable="false"
					style="-fx-alignment: CENTER"/>
			<TableColumn fx:id="clCommit" editable="false" maxWidth="1000.0" sortable="false" text="Commit"
					style="-fx-alignment: CENTER; -fx-font-weight: bold"/>
			<TableColumn fx:id="clMessage" editable="false" maxWidth="9000.0" sortable="false" text="Message"/>
			<TableColumn fx:id="clUser" editable="false" maxWidth="4000.0" sortable="false" text="Author"
					style="-fx-alignment: CENTER; -fx-font-weight: bold"/>
			<TableColumn fx:id="clDate" editable="false" maxWidth="2000.0" sortable="false" text="Date"
					style="-fx-alignment: CENTER"/>
			<TableColumn fx:id="clTags" editable="false" maxWidth="3000.0" sortable="false" text="Tags"/>
		</columns>
		<columnResizePolicy>
			<TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
		</columnResizePolicy>
	</TableView>
</fx:root>
