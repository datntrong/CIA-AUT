<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?><?import javafx.scene.control.Button?><?import javafx.scene.control.CheckBox?><?import javafx.scene.layout.HBox?><?import javafx.scene.layout.VBox?><?import uet.fit.client.ui.view.CommitChoosingTableView?>
<VBox fx:id="content" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
		fx:controller="uet.fit.client.ui.controller.cia.CommitsChoosingController">
	<HBox fx:id="hbVersions" spacing="4.0">
		<padding>
			<Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
		</padding>
	</HBox>
	<HBox alignment="CENTER" spacing="4.0">
		<Button fx:id="bFetchRepository" mnemonicParsing="false" text="Fetch repository" HBox.hgrow="SOMETIMES"/>
		<Button fx:id="bCompareCommits" mnemonicParsing="false" text="Compare commits" HBox.hgrow="SOMETIMES"/>
		<CheckBox fx:id="cbForceReload" mnemonicParsing="false" text="Force reload" HBox.hgrow="SOMETIMES"/>
	</HBox>
	<CommitChoosingTableView fx:id="tvCommits" VBox.vgrow="ALWAYS"/>
</VBox>
