<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="460.0" prefWidth="660.0" xmlns="http://javafx.com/javafx/11.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uet.fit.client.ui.controller.dialogs.ExportTestCaseController">
   <children>
      <Button fx:id="browserButton" layoutX="568.0" layoutY="16.0" mnemonicParsing="false" onAction="#browser_Clicked" prefHeight="26.0" prefWidth="74.0" text="Browser" />
      <Label layoutX="14.0" layoutY="19.0" prefHeight="18.0" prefWidth="89.0" text="Path export" />
      <TextField fx:id="pathExportFile" layoutX="110.0" layoutY="16.0" prefHeight="26.0" prefWidth="440.0" />
      <CheckBox fx:id="selectAll" layoutX="13.0" layoutY="78.0" mnemonicParsing="false" prefHeight="18.0" prefWidth="90.0" text="Select all" />
      <TableView fx:id="chooseTestTable" layoutX="5.0" layoutY="108.0" prefHeight="309" prefWidth="665.0">
        <columns>
			<TableColumn fx:id="colChoose" editable="false" maxWidth="30.0" minWidth="30.0" sortable="false" />
            <TableColumn fx:id="colName" prefWidth="200" text="Name" />
            <TableColumn fx:id="colFunc" prefWidth="150" text="Function" />
            <TableColumn fx:id="colStatus" prefWidth="95" text="Status" />
            <TableColumn fx:id="colCoverage" prefWidth="95" text="Coverage" />
            <TableColumn fx:id="colAuthor" prefWidth="95" text="Author" />
        </columns>
      </TableView>
      <Button layoutX="568.0" layoutY="433.0" mnemonicParsing="false" onAction="#export_Clicked" prefHeight="26.0" prefWidth="74.0" text="Export" />
   </children>
</AnchorPane>
